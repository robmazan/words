{
  "routes": [
    { "route": "/api/*", "allowedRoles": ["authenticated"] },
    { "route": "/login", "allowedRoles": ["anonymous"] },
    {
      "route": "/*",
      "allowedRoles": ["authenticated"],
      "redirect": "/login"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/animals/*", "/badges/*", "/*.svg", "/*.png"]
  },
  "responseOverrides": {
    "401": {
      "redirect": "/login",
      "statusCode": 302
    }
  }
}
