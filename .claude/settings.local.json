{
  "permissions": {
    "allow": [
      "Bash(npm install *)",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_tabs",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_type",
      "mcp__playwright__browser_console_messages"
    ]
  },
  "enabledMcpjsonServers": [
    "playwright"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys,json; d=json.load(sys.stdin); print(d.get('tool_input',{}).get('file_path',''))\" | { read -r f; case \"$f\" in *.ts) npm run build && npm run api:build ;; esac; }",
            "timeout": 120,
            "statusMessage": "Building frontend and API...",
            "async": true
          }
        ]
      }
    ]
  }
}
